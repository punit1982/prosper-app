# ============================================
# Project Prosper - API Keys
# ============================================
# Copy this file to .env and fill in your real keys.
# NEVER commit the .env file to version control.

# Anthropic Claude API Key (for screenshot parsing)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Financial Modeling Prep API Key (for stock data)
# Get yours at: https://financialmodelingprep.com/developer
FMP_API_KEY=your_fmp_api_key_here

# Base currency for portfolio normalization (default: USD)
BASE_CURRENCY=USD
