# ============================================
# Prosper — Environment Variables
# ============================================
# Copy this file to .env and fill in your real keys.
# NEVER commit the .env file to version control.

# ── Required ──────────────────────────────────
# Anthropic Claude API Key (AI features: screenshot parsing, chat, analysis)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Authentication ────────────────────────────
# Enable/disable authentication (set to false for local dev)
PROSPER_AUTH_ENABLED=true

# Secret key for session cookies (MUST be set in production — generates random if missing)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
PROSPER_COOKIE_SECRET=

# Google OAuth cookie secret (optional, for Google sign-in)
PROSPER_GOOGLE_COOKIE_SECRET=

# ── Google OAuth (optional) ───────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ── Database (optional — defaults to local SQLite) ──
# Turso cloud database for persistent storage across deploys
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ── Optional API Keys (enhance features) ─────
# Base currency for portfolio normalization (default: USD)
BASE_CURRENCY=USD

# Finnhub — analyst data, company news (free at finnhub.io)
FINNHUB_API_KEY=

# Twelve Data — UAE/DFM stock quotes (free at twelvedata.com)
TWELVE_DATA_API_KEY=

# Serper — Google-powered news search (free 2.5K/month at serper.dev)
SERPER_API_KEY=

# Financial Modeling Prep — additional financial data (free at financialmodelingprep.com)
FMP_API_KEY=

# IBKR Flex Query — Interactive Brokers sync
IBKR_FLEX_TOKEN=
